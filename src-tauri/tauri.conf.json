{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "steam-presence",
    "version": "0.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "http": {
        "all": false,
        "request": true,
        "scope": [
          "http://api.steampowered.com/ISteamUser/GetPlayerSummaries/v0002*"
        ]
      },
      "shell": {
        "all": false,
        "execute": false,
        "open": "https://store.steampowered.com/account|https://steamcommunity.com/dev/apikey",
        "scope": [],
        "sidecar": false
      }
    },
    "bundle": {
      "active": true,
      "category": "public.app-category.social-networking",
      "copyright": "© 2022 Darin Morrison All Rights Reserved",
      "deb": {
        "depends": []
      },
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "io.github.silvanshade.steam-presence",
      "longDescription": "",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      },
      "resources": [],
      "shortDescription": "",
      "targets": "all",
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      }
    },
    "security": {
      "csp": "img-src tauri://localhost/assets/steam.4123825c.svg; style-src tauri://localhost/assets/index.801beb36.css"
    },
    "systemTray": {
      "iconAsTemplate": true,
      "iconPath": "icons/icon.png"
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 222,
        "resizable": true,
        "title": "Steam Presence",
        "width": 600
      }
    ]
  }
}